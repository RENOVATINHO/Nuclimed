// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  clinica       Clinica?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Clinica {
  id        String   @id @default(cuid())
  nome      String
  cnpj      String?
  telefone  String?
  email     String?
  endereco  String?
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  pacientes Paciente[]
  consultas Consulta[]
  agendamentos Agendamento[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Paciente {
  id          String   @id @default(cuid())
  nome        String
  cpf         String?
  dataNasc    DateTime?
  telefone    String?
  email       String?
  endereco    String?
  clinicaId   String
  clinica     Clinica  @relation(fields: [clinicaId], references: [id])
  consultas   Consulta[]
  agendamentos Agendamento[]
  avaliacoesMev AvaliacaoMev[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Consulta {
  id          String   @id @default(cuid())
  data        DateTime
  observacoes String?  @db.Text
  status      String   @default("AGENDADA")
  pacienteId  String
  clinicaId   String
  paciente    Paciente @relation(fields: [pacienteId], references: [id])
  clinica     Clinica  @relation(fields: [clinicaId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Agendamento {
  id         String   @id @default(cuid())
  data       DateTime
  status     String   @default("PENDENTE")
  tipo       String?
  pacienteId String
  clinicaId  String
  paciente   Paciente @relation(fields: [pacienteId], references: [id])
  clinica    Clinica  @relation(fields: [clinicaId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model AvaliacaoMev {
  id         String   @id @default(cuid())
  data       DateTime @default(now())
  peso       Float?
  altura     Float?
  imc        Float?
  observacoes String? @db.Text
  pacienteId String
  paciente   Paciente @relation(fields: [pacienteId], references: [id])
  planoMev   PlanoMev?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model PlanoMev {
  id           String       @id @default(cuid())
  titulo       String
  descricao    String?      @db.Text
  avaliacaoId  String       @unique
  avaliacao    AvaliacaoMev @relation(fields: [avaliacaoId], references: [id])
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}
